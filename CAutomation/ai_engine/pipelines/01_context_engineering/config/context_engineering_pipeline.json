{
  "pipelineId": "01_context_engineering",
  "pipelineName": "Pipeline 01 - Context Engineering",
  "pipelineVersion": "mvp-009",
  "projectId": "pipeline_management",
  "moduleId": "pipeline_management",
  "taskRegistryPath": "CAutomation/ai_engine/pipelines/01_context_engineering/config/task_definitions.json",
  "input": {
    "CAutomationRoot": "CAutomation",
    "projectConfigPath": "projects/{projectId}/project.json",
    "moduleInputPath": "projects/{projectId}/input/modules/{moduleId}",
    "srsFileName": "Software_Requirements_Specification.docx",
    "atsFileName": "Architecture_and_Technical_Specification.docx",
    "normalizedInputPath": "projects/{projectId}/normalized_input/modules/{moduleId}"
  },
  "output": {
    "contextPackageRoot": "projects/{projectId}/output/context_packages",
    "contextPackageId": "{projectId}_{moduleId}_context_package",
    "cleanPackageBeforeWrite": true,
    "pipelineStateRoot": "CAutomation/ai_engine/pipelines/01_context_engineering/output/current_run",
    "taskReportsDirectory": "CAutomation/ai_engine/pipelines/01_context_engineering/output/current_run/task_reports",
    "finalReportDirectory": "CAutomation/ai_engine/pipelines/01_context_engineering/output",
    "executionHistoryRoot": "CAutomation/ai_engine/pipelines/01_context_engineering/output/executions",
    "archiveCurrentRun": true
  },
  "contextFiles": {
    "globalContext": "global-context.md",
    "projectContext": "project-context.md",
    "moduleContext": "module-context.md",
    "architectureContext": "architecture-context.md",
    "constraintsContext": "constraints-context.md",
    "generationContext": "generation-context.md",
    "sourceIndex": "source_index.md",
    "openQuestions": "open_questions.md"
  },
  "structuredFiles": {
    "manifest": "manifest.json",
    "provenance": "provenance.json",
    "validationReport": "validation_report.json"
  },
  "validation": {
    "warnWhenProjectClientContractsMissing": true,
    "warnWhenProjectEngineeringContractsMissing": true,
    "inputQualityGate": {
      "enabled": true,
      "minimumExtractedCharacters": 500,
      "forbiddenPlaceholderTokens": [
        "TBD",
        "TODO",
        "FIXME",
        "???",
        "<placeholder>",
        "[placeholder]"
      ],
      "requiredHierarchyTerms": [
        "CAutomation",
        "CCore",
        "Pipeline Management"
      ],
      "manualInputDocuments": [
        {
          "documentId": "srs",
          "fileNameKey": "srsFileName",
          "displayName": "Software Requirements Specification",
          "requiredTerms": [
            "Purpose",
            "Scope",
            "Business Context",
            "Workflow",
            "Validation",
            "Acceptance"
          ],
          "normalizedFileName": "module_srs.md"
        },
        {
          "documentId": "ats",
          "fileNameKey": "atsFileName",
          "displayName": "Architecture and Technical Specification",
          "requiredTerms": [
            "Architecture",
            "Traceability",
            "Database",
            "API",
            "Validation",
            "Testing"
          ],
          "normalizedFileName": "module_ats.md"
        }
      ],
      "crossDocumentReferences": [
        {
          "sourceDocumentId": "srs",
          "requiredTerm": "ATS"
        },
        {
          "sourceDocumentId": "ats",
          "requiredTerm": "SRS"
        }
      ],
      "supportedSourceFormats": [
        "pdf",
        "docx",
        "md"
      ]
    }
  },
  "downstreamConsumers": [
    "02_planning",
    "03_generation/db",
    "03_generation/backend",
    "03_generation/frontend",
    "03_generation/testing",
    "03_generation/deployment",
    "04_validation"
  ],
  "scopeBoundary": "Only the Pipeline Management reference module is in scope for this context package.",
  "firstDeliverable": "The first deliverable is the executable CAutomation package, validated through the Pipeline Management reference module.",
  "taskInstances": [
