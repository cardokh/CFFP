{
    "pipelines": [
        {
            "id": "validate-automation-task",
            "name": "Validate Automation Task",
            "description": "Validates an automation task by loading configuration, validating configuration, inspecting script governance, collecting results, and preparing a validation report.",
            "category": "validation",
            "status": "ready",
            "version": "1.0",
            "execution_mode": "sequential",
            "failure_strategy": "stop_on_first_failure",
            "steps": [
                {
                    "id": "load-configuration",
                    "order": 1,
                    "name": "Load Configuration",
                    "task_id": "load-configuration",
                    "required": true
                },
                {
                    "id": "validate-configuration",
                    "order": 2,
                    "name": "Validate Configuration",
                    "task_id": "validate-configuration",
                    "required": true
                },
                {
                    "id": "inspect-script-governance",
                    "order": 3,
                    "name": "Inspect Script Governance",
                    "task_id": "inspect-script-governance",
                    "required": true
                },
                {
                    "id": "collect-results",
                    "order": 4,
                    "name": "Collect Results",
                    "task_id": "collect-results",
                    "required": true
                },
                {
                    "id": "produce-validation-report",
                    "order": 5,
                    "name": "Produce Validation Report",
                    "task_id": "produce-validation-report",
                    "required": true
                }
            ]
        }
    ]
}