{
    "scriptName": "db_pipeline",
    "mode": "database_crud_pipeline",
    "databaseEngine": "postgres",
    "execution": {
        "stopOnFailure": true,
        "recreateDatabase": false,
        "recreateExistingTables": true,
        "dropUnlistedTables": true
    },
    "components": [
        {
            "name": "validate_postgres_metadata",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/implementations/postgres/tasks/validate_postgres_metadata/validate_postgres_metadata.py"
        },
        {
            "name": "build_database",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/implementations/postgres/tasks/build_database/build_database.py"
        },
        {
            "name": "insert_data",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/implementations/postgres/tasks/insert_data/insert_data.py"
        }
    ]
}
