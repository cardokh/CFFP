{
    "scriptName": "db_task",
    "mode": "database_crud_task",
    "databaseEngine": "postgres",
    "execution": {
        "stopOnFailure": true,
        "recreateDatabase": false,
        "recreateExistingTables": true,
        "dropUnlistedTables": true
    },
    "components": [
        {
            "name": "generate_table_metadata",
            "enabled": false,
            "scriptPath": "automation/factory/crud/db/postgres/generate_table_metadata/generate_table_metadata.py"
        },
        {
            "name": "promote_db_metadata",
            "enabled": false,
            "scriptPath": "automation/factory/crud/db/postgres/promote_db_metadata/promote_db_metadata.py"
        },
        {
            "name": "create_db_schema",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/postgres/create_db_schema.py"
        },
        {
            "name": "seed_db_data",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/postgres/seed_db_data.py"
        },
        {
            "name": "build_db_context",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/postgres/context/build_db_context.py"
        }
    ]
}