{
    "scriptName": "db_task",
    "mode": "database_crud_task",
    "databaseEngine": "postgres",
    "execution": {
        "stopOnFailure": true,
        "recreateDatabase": false,
        "recreateExistingTables": true,
        "dropUnlistedTables": true
    },
    "components": [
        {
            "name": "add_task",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/postgres/add/add_task.py"
        },
        {
            "name": "build_db_context",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/postgres/context/build_db_context.py"
        },
        {
            "name": "create_schema",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/postgres/create_schema.py"
        },
        {
            "name": "seed_data",
            "enabled": true,
            "scriptPath": "automation/factory/crud/db/postgres/seed_data.py"
        }
    ]
}
