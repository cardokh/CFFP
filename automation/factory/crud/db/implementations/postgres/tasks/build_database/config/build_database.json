{
    "scriptName": "build_database",
    "mode": "build_postgres_database_from_generic_metadata",
    "metadataRoot": "metadata",
    "implementationRoot": "implementations/postgres",
    "outputFileName": "database.sql",
    "moduleRoots": [
        "ccore/automation",
        "ccore/organization"
    ],
    "typeMappings": {
        "integer": "INTEGER",
        "uuid": "UUID",
        "string": "VARCHAR(255)",
        "text": "TEXT",
        "boolean": "BOOLEAN",
        "timestamp": "TIMESTAMP WITH TIME ZONE",
        "json": "JSONB"
    },
    "defaultMappings": {
        "currentTimestamp": "CURRENT_TIMESTAMP",
        "generatedUuid": "gen_random_uuid()",
        "emptyJson": "'{}'::jsonb"
    },
    "executeSql": true,
    "execution": {
        "recreateDatabase": false,
        "dropUnlistedTables": true,
        "recreateExistingTables": true
    }
}