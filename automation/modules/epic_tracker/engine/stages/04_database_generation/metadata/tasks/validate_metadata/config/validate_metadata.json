{
    "scriptName": "validate_metadata",
    "mode": "validate_generic_metadata",
    "metadataRoot": "metadata",
    "requiredDatabaseFields": [
        "name",
        "version",
        "description",
        "currentImplementation"
    ],
    "moduleRoots": [
        "ccore/automation"
    ],
    "validateImplementationConfig": false,
    "validateDataRows": true,
    "validateTaskModel": true,
    "expectedTaskFolders": [
        "generate_table_metadata",
        "remove_metadata_tables",
        "validate_metadata"
    ],
    "forbiddenTaskFolders": [
        "add_metadata_tables",
        "update_metadata_table"
    ],
    "validateGenerateTask": true,
    "validateRemoveTask": true
}
