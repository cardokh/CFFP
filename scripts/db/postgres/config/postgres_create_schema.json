{
    "scriptName": "postgres_create_schema",
    "mode": "create_schema",
    "databaseConfigPath": "scripts/db/postgres/config/database.json",
    "entitiesConfigPath": "scripts/db/postgres/config/entities.json",
    "tables": {
        "ccore_task_statuses": {
            "columns": [
                {
                    "name": "status_code",
                    "type": "VARCHAR(50)",
                    "primaryKey": true
                },
                {
                    "name": "status_label",
                    "type": "VARCHAR(100)",
                    "nullable": false
                },
                {
                    "name": "sort_order",
                    "type": "INTEGER",
                    "nullable": false
                }
            ]
        },
        "ccore_tasks": {
            "columns": [
                {
                    "name": "task_id",
                    "type": "UUID",
                    "primaryKey": true
                },
                {
                    "name": "task_name",
                    "type": "VARCHAR(255)",
                    "nullable": false
                },
                {
                    "name": "status_code",
                    "type": "VARCHAR(50)",
                    "nullable": false,
                    "default": "'PENDING'"
                },
                {
                    "name": "created_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "nullable": false,
                    "default": "CURRENT_TIMESTAMP"
                },
                {
                    "name": "updated_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "nullable": false,
                    "default": "CURRENT_TIMESTAMP"
                }
            ],
            "constraints": [
                {
                    "type": "foreignKey",
                    "columns": [
                        "status_code"
                    ],
                    "references": {
                        "table": "ccore_task_statuses",
                        "columns": [
                            "status_code"
                        ]
                    },
                    "onDelete": "RESTRICT"
                }
            ]
        },
        "ccore_metric_types": {
            "columns": [
                {
                    "name": "metric_type_code",
                    "type": "VARCHAR(50)",
                    "primaryKey": true
                },
                {
                    "name": "metric_type_label",
                    "type": "VARCHAR(100)",
                    "nullable": false
                },
                {
                    "name": "sort_order",
                    "type": "INTEGER",
                    "nullable": false
                }
            ]
        },
        "ccore_metrics": {
            "columns": [
                {
                    "name": "metric_id",
                    "type": "UUID",
                    "primaryKey": true
                },
                {
                    "name": "metric_name",
                    "type": "VARCHAR(255)",
                    "nullable": false
                },
                {
                    "name": "metric_key",
                    "type": "VARCHAR(150)",
                    "nullable": false,
                    "unique": true
                },
                {
                    "name": "metric_type_code",
                    "type": "VARCHAR(50)",
                    "nullable": false,
                    "default": "'COUNTER'"
                },
                {
                    "name": "created_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "nullable": false,
                    "default": "CURRENT_TIMESTAMP"
                },
                {
                    "name": "updated_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "nullable": false,
                    "default": "CURRENT_TIMESTAMP"
                }
            ],
            "constraints": [
                {
                    "type": "foreignKey",
                    "columns": [
                        "metric_type_code"
                    ],
                    "references": {
                        "table": "ccore_metric_types",
                        "columns": [
                            "metric_type_code"
                        ]
                    },
                    "onDelete": "RESTRICT"
                }
            ]
        },
        "ccore_task_execution_statuses": {
            "columns": [
                {
                    "name": "status_code",
                    "type": "VARCHAR(50)",
                    "primaryKey": true
                },
                {
                    "name": "status_label",
                    "type": "VARCHAR(100)",
                    "nullable": false
                },
                {
                    "name": "sort_order",
                    "type": "INTEGER",
                    "nullable": false
                }
            ]
        },
        "ccore_task_executions": {
            "columns": [
                {
                    "name": "execution_id",
                    "type": "UUID",
                    "primaryKey": true
                },
                {
                    "name": "task_id",
                    "type": "UUID",
                    "nullable": false
                },
                {
                    "name": "status_code",
                    "type": "VARCHAR(50)",
                    "nullable": false
                },
                {
                    "name": "runner_code",
                    "type": "VARCHAR(100)",
                    "nullable": true
                },
                {
                    "name": "report_json",
                    "type": "JSONB",
                    "nullable": false,
                    "default": "'{}'::jsonb"
                },
                {
                    "name": "started_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "nullable": false,
                    "default": "CURRENT_TIMESTAMP"
                },
                {
                    "name": "finished_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "nullable": false,
                    "default": "CURRENT_TIMESTAMP"
                },
                {
                    "name": "created_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "nullable": false,
                    "default": "CURRENT_TIMESTAMP"
                }
            ],
            "constraints": [
                {
                    "type": "foreignKey",
                    "columns": [
                        "task_id"
                    ],
                    "references": {
                        "table": "ccore_tasks",
                        "columns": [
                            "task_id"
                        ]
                    },
                    "onDelete": "CASCADE"
                },
                {
                    "type": "foreignKey",
                    "columns": [
                        "status_code"
                    ],
                    "references": {
                        "table": "ccore_task_execution_statuses",
                        "columns": [
                            "status_code"
                        ]
                    },
                    "onDelete": "RESTRICT"
                }
            ]
        }
    }
}
